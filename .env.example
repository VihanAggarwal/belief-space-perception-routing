# Copy to .env and fill in. .env is gitignored.

# Where the raw TartanDrive2 bag(s) live and where extracted frames go.
# Defaults match config.yaml; override here if your data lives elsewhere.
DATA_ROOT=data
RAW_BAG=data/raw/turnpike_afternoon_fall_0.bag
FRAMES_DIR=data/frames/turnpike_afternoon_fall_0

# Device override: auto | cpu | cuda
DEVICE=auto

# Public TartanDrive2 Swift endpoint (no credentials needed, unsigned access).
TARTAN_SWIFT_ENDPOINT=https://airlab-cloud.andrew.cmu.edu:8080/swift/v1/AUTH_ac8533a83cff4d48bc8c608ad222d330
TARTAN_BUCKET=tartandrive2

# Number of frames to extract from the bag (0 = all available).
EXTRACT_MAX_FRAMES=0
